global
    log /dev/log local0
    maxconn 4096
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5s
    timeout client  50s
    timeout server  50s

frontend flask_frontend
    bind *:5000
    default_backend flask_backend

backend flask_backend
    balance roundrobin
{% for ip in node_ips.split(',') %}
    server node{{ loop.index }} {{ ip }}:5000 check
{% endfor %}
